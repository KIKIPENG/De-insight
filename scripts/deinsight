#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND_PY="$ROOT_DIR/backend/.venv/bin/python"
HEALTH_URL="http://127.0.0.1:8000/api/health"
LOG_DIR="$HOME/.deinsight/logs"
BACKEND_LOG="$LOG_DIR/backend.log"

if [ ! -x "$BACKEND_PY" ]; then
  echo "Backend environment not found."
  echo "Run: $ROOT_DIR/scripts/install.sh"
  exit 1
fi

mkdir -p "$LOG_DIR"

is_backend_ready() {
  if command -v curl >/dev/null 2>&1; then
    curl -sS --max-time 1 "$HEALTH_URL" >/dev/null 2>&1
    return $?
  fi
  "$BACKEND_PY" - <<'PY' >/dev/null 2>&1
import sys, urllib.request
try:
    urllib.request.urlopen("http://127.0.0.1:8000/api/health", timeout=1)
except Exception:
    sys.exit(1)
PY
}

start_backend() {
  if is_backend_ready; then
    echo "[deinsight] backend already running on 127.0.0.1:8000"
    return 0
  fi

  echo "[deinsight] starting backend..."
  (
    cd "$ROOT_DIR/backend"
    nohup "$BACKEND_PY" -m uvicorn main:app --host 127.0.0.1 --port 8000 >>"$BACKEND_LOG" 2>&1 &
  )

  for _ in $(seq 1 30); do
    if is_backend_ready; then
      echo "[deinsight] backend ready"
      return 0
    fi
    sleep 0.2
  done

  echo "[deinsight] backend failed to start."
  echo "See log: $BACKEND_LOG"
  exit 1
}

start_backend
cd "$ROOT_DIR"
echo "[deinsight] starting TUI..."
exec "$BACKEND_PY" tui.py
